{
  "name": "claude-alfred",
  "version": "0.5.5",
  "type": "module",
  "bin": {
    "alfred": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "web/dist/",
    "templates/",
    "content/"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "build": "tsdown",
    "build:web": "cd web && npm run build",
    "dev": "bun --watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ web/src/",
    "lint:fix": "biome check --write src/ web/src/",
    "test": "bunx --bun vitest run",
    "test:watch": "bunx --bun vitest",
    "postinstall": "bun dist/postinstall.mjs || true",
    "prepack": "npm run build:web && npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@modelcontextprotocol/sdk": "^1.27",
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "@tsconfig/node22": "^22.0.5",
    "@types/bun": "^1.3.11",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3.2.4",
    "citty": "^0.2",
    "eta": "^4",
    "hono": "^4",
    "tsdown": "^0",
    "typescript": "^5.8",
    "vitest": "^3",
    "yaml": "^2",
    "zod": "^3"
  }
}
