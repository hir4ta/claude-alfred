{
  "on_write": {
    "lint": {
      "command": "biome check {file}",
      "timeout": 3000
    },
    "typecheck": {
      "command": "bun tsc --noEmit",
      "timeout": 10000,
      "run_once_per_batch": true
    }
  },
  "on_commit": {
    "test": {
      "command": "bun vitest run",
      "timeout": 30000
    }
  }
}